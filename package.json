{
  "name": "build-your-goat",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Build Your GOAT — strategic, competitive sports GOAT-builder. Vanilla TS engine + DOM UI, no runtime dependencies.",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "@types/node": "^22.9.0",
    "@vitest/coverage-v8": "^2.1.4",
    "eslint": "^9.13.0",
    "globals": "^15.11.0",
    "jsdom": "^25.0.1",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.12.2",
    "vite": "^5.4.10",
    "vitest": "^2.1.4"
  }
}
